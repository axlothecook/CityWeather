# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored — never commit real keys.
# Vite only exposes variables prefixed with VITE_ to the app.

# Google Cloud API key — needs Maps JavaScript API, Places API,
# Places API (New), and YouTube Data API v3 enabled on the key.
VITE_GOOGLE_MAPS_API_KEY=

# Visual Crossing weather API key (https://www.visualcrossing.com/weather-api/)
VITE_VISUAL_CROSSING_API_KEY=
